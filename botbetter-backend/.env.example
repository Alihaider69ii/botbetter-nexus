# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:8080

# ─── CRACKY agent providers (tried in order, first available wins) ──────────
# 1. Gemini — FREE FOREVER, 1,500 req/day
GEMINI_CRACKY=your_gemini_api_key

# 2. Groq — FREE FOREVER, 500,000 tokens/day
GROQ_CRACKY=your_groq_api_key

# 3. Mistral — FREE, rate-limited (1 req/sec)
MISTRAL_CRACKY=your_mistral_api_key

# 4. Together AI — $5 one-time credit backup
TOGETHER_CRACKY=your_together_api_key

# 5. DeepSeek — $5 one-time credit backup
DEEPSEEK_CRACKY=your_deepseek_api_key

# ─── SELLIO agent providers (same priority order, separate quota) ────────────
GEMINI_SELLIO=your_gemini_api_key
GROQ_SELLIO=your_groq_api_key
MISTRAL_SELLIO=your_mistral_api_key
TOGETHER_SELLIO=your_together_api_key
DEEPSEEK_SELLIO=your_deepseek_api_key
